# ============================================================
# WILLVIRAL — Environment Variables
# Másold .env.local-ba és töltsd ki az értékeket
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# YouTube Data API v3
YOUTUBE_API_KEY=AXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Fejlesztési backup kulcs (opcionális, csak dev módban használt)
YOUTUBE_API_KEY_DEV_BACKUP=

# Serper.dev — webes/hír-keresés (Trend Radar, Opportunity Engine, Viral Score webes visszhang)
SERPER_API_KEY=

# Stripe — előfizetés/kredit vásárlás
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_STARTER_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_CREATOR_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=WillViral

# Cron — /api/cron/refresh-trends védelme (Vercel automatikusan küldi
# Authorization: Bearer $CRON_SECRET fejlécet, ha ez az env változó be van állítva)
# FONTOS: deploy előtt állítsd be — enélkül a végpont hitelesítés nélkül,
# nyilvánosan hívható marad.
CRON_SECRET=

# ============================================================
# VERCEL-EN ezeket Environment Variables-ként add meg:
# Settings → Environment Variables
# ============================================================
